{
    "serviceId": "passport",
    "formTitle": {
        "en": "Passport Application (SP-1)",
        "hi": "पासपोर्ट आवेदन फॉर्म (SP-1)",
        "mr": "पासपोर्ट अर्ज (SP-1)",
        "ta": "கடவுச்சீட்டு விண்ணப்பம் (SP-1)"
    },
    "portalName": "Passport Seva",
    "officialUrl": "https://passportindia.gov.in",
    "introExplanation": {
        "en": "This is the Indian Passport application form. I will help you fill it using your uploaded documents. After filling, you can apply on the Passport Seva portal.",
        "hi": "यह भारतीय पासपोर्ट आवेदन फॉर्म है। मैं आपके अपलोड किए गए दस्तावेज़ों का उपयोग करके इसे भरने में मदद करूँगा।",
        "mr": "हा भारतीय पासपोर्ट अर्ज आहे. मी तुमच्या अपलोड केलेल्या कागदपत्रांचा वापर करून ते भरण्यात मदत करेन.",
        "ta": "இது இந்திய கடவுச்சீட்டு விண்ணப்ப படிவம். உங்கள் பதிவேற்றிய ஆவணங்களைப் பயன்படுத்தி நிரப்ப உதவுவேன்."
    },
    "requiredDocuments": [
        "aadhaar",
        "pan"
    ],
    "optionalDocuments": [
        "photo"
    ],
    "submitSteps": [
        {
            "step": 1,
            "instruction": {
                "en": "Register on Passport Seva portal",
                "hi": "पासपोर्ट सेवा पोर्टल पर रजिस्टर करें"
            }
        },
        {
            "step": 2,
            "instruction": {
                "en": "Fill the online form with your details shown below",
                "hi": "नीचे दिखाए गए विवरण के साथ ऑनलाइन फॉर्म भरें"
            }
        },
        {
            "step": 3,
            "instruction": {
                "en": "Upload passport-size photograph",
                "hi": "पासपोर्ट साइज फोटो अपलोड करें"
            }
        },
        {
            "step": 4,
            "instruction": {
                "en": "Pay the application fee online",
                "hi": "ऑनलाइन आवेदन शुल्क का भुगतान करें"
            }
        },
        {
            "step": 5,
            "instruction": {
                "en": "Book appointment at nearest Passport Seva Kendra",
                "hi": "निकटतम पासपोर्ट सेवा केंद्र में अपॉइंटमेंट बुक करें"
            }
        }
    ],
