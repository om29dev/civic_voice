{
    "serviceId": "driving_license",
    "formTitle": {
        "en": "Driving License Application",
        "hi": "ड्राइविंग लाइसेंस आवेदन",
        "mr": "वाहन चालक परवाना अर्ज",
        "ta": "ஓட்டுநர் உரிமம் விண்ணப்பம்"
    },
    "portalName": "Parivahan (Sarathi)",
    "officialUrl": "https://parivahan.gov.in",
    "introExplanation": {
        "en": "This is the Driving License application form. Apply through the Parivahan Sarathi portal and book an RTO appointment.",
        "hi": "यह ड्राइविंग लाइसेंस आवेदन फॉर्म है। परिवहन सारथी पोर्टल के माध्यम से आवेदन करें।",
        "mr": "हा वाहन चालक परवाना अर्ज आहे. परिवहन सारथी पोर्टलद्वारे अर्ज करा.",
        "ta": "இது ஓட்டுநர் உரிமம் விண்ணப்ப படிவம். பரிவாகன் சாரதி போர்ட்டல் மூலம் விண்ணப்பிக்கவும்."
    },
    "requiredDocuments": [
        "aadhaar"
    ],
    "optionalDocuments": [
        "photo"
    ],
    "submitSteps": [
        {
            "step": 1,
            "instruction": {
                "en": "Go to Parivahan Sarathi portal",
                "hi": "परिवहन सारथी पोर्टल पर जाएं"
            }
        },
        {
            "step": 2,
            "instruction": {
                "en": "Select your state and 'New Driving License'",
                "hi": "अपना राज्य और 'नया ड्राइविंग लाइसेंस' चुनें"
            }
        },
        {
            "step": 3,
            "instruction": {
                "en": "Fill personal details from the data below",
                "hi": "नीचे दिए गए डेटा से व्यक्तिगत विवरण भरें"
            }
        },
        {
            "step": 4,
            "instruction": {
                "en": "Upload photo and documents",
                "hi": "फोटो और दस्तावेज़ अपलोड करें"
            }
        },
        {
            "step": 5,
            "instruction": {
                "en": "Book slot at nearest RTO",
                "hi": "निकटतम आरटीओ पर स्लॉट बुक करें"
            }
        }
    ],
