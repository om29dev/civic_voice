{
    "serviceId": "senior_citizen_pension",
    "formTitle": {
        "en": "Old Age Pension (IGNOAPS)",
        "hi": "वृद्धावस्था पेंशन (IGNOAPS)",
        "mr": "वृद्धापकाळ पेन्शन",
        "ta": "முதியோர் ஓய்வூதியம்"
    },
    "portalName": "NSAP Portal",
    "officialUrl": "https://nsap.nic.in",
    "introExplanation": {
        "en": "Old Age Pension form. Apply at District Social Welfare Office or CSC.",
        "hi": "वृद्धावस्था पेंशन फॉर्म। जिला समाज कल्याण कार्यालय में आवेदन करें।",
        "mr": "वृद्धापकाळ पेन्शन अर्ज. जिल्हा समाजकल्याण कार्यालयात अर्ज करा.",
        "ta": "முதியோர் ஓய்வூதிய படிவம். மாவட்ட சமூக நல அலுவலகத்தில் விண்ணப்பிக்கவும்."
    },
    "requiredDocuments": [
        "aadhaar"
    ],
    "optionalDocuments": [
        "bankPassbook",
        "incomeCertificate"
    ],
    "submitSteps": [
        {
            "step": 1,
            "instruction": {
                "en": "Visit District Social Welfare Office or CSC",
                "hi": "जिला समाज कल्याण कार्यालय या CSC जाएं"
            }
        },
        {
            "step": 2,
            "instruction": {
                "en": "Fill personal and bank details",
                "hi": "व्यक्तिगत और बैंक विवरण भरें"
            }
        },
        {
            "step": 3,
            "instruction": {
                "en": "Submit Aadhaar and age proof",
                "hi": "आधार और आयु प्रमाण जमा करें"
            }
        },
        {
            "step": 4,
            "instruction": {
                "en": "Collect acknowledgment receipt",
                "hi": "पावती रसीद प्राप्त करें"
            }
        }
    ],
