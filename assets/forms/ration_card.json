    "introExplanation": {
        "en": "Ration Card form for food security benefits.",
        "hi": "खाद्य सुरक्षा लाभों के लिए राशन कार्ड फॉर्म।",
        "mr": "अन्न सुरक्षा लाभांसाठी शिधापत्रिका अर्ज.",
        "ta": "உணவுப் பாதுகாப்புக்கான ரேஷன் அட்டை படிவம்."
    },
    "requiredDocuments": [
        "aadhaar"
    ],
    "optionalDocuments": [
        "incomeCertificate"
    ],
    "submitSteps": [
        {
            "step": 1,
            "instruction": {
                "en": "Visit state food supply portal",
                "hi": "राज्य खाद्य आपूर्ति पोर्टल पर जाएं"
            }
        },
        {
            "step": 2,
            "instruction": {
                "en": "Fill family head details",
                "hi": "परिवार मुखिया का विवरण भरें"
            }
        },
        {
            "step": 3,
            "instruction": {
                "en": "Upload Aadhaar and income certificate",
                "hi": "आधार और आय प्रमाणपत्र अपलोड करें"
            }
        },
        {
            "step": 4,
            "instruction": {
                "en": "Submit application",
                "hi": "आवेदन जमा करें"
            }
        }
    ],
